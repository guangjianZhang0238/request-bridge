{
  "name": "request-bridge",
  "version": "0.3.0",
  "description": "Explicit forward proxy with desktop console - remap HTTP/HTTPS requests from A to B.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "check": "node --check src/server.js && node --check src/bridge.js && node --check src/config.js && node --check desktop/main.js && node --check desktop/preload.js && node --check desktop/renderer/renderer.js",
    "demo:upstream": "node scripts/demo-upstream.js",
    "demo:client": "node scripts/demo-client.js",
    "demo": "node scripts/run-demo.js",
    "desktop": "electron desktop/main.js",
    "pack:win": "electron-builder --win portable nsis",
    "pack:mac": "electron-builder --mac",
    "pack:linux": "electron-builder --linux AppImage deb"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "ai.openclaw.requestbridge",
    "productName": "Request Bridge",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "desktop/**/*",
      "scripts/**/*",
      "package.json",
      ".env.example",
      "README.md",
      "docs/**/*"
    ],
    "extraResources": [
      {
        "from": ".env.example",
        "to": ".env.example"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-${arch}-installer.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Request Bridge"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build/icons",
      "category": "Network"
    },
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ]
  }
}
